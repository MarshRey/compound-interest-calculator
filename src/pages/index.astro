---
import Layout from '../components/Layout.astro';
import AffiliateLink from '../components/AffiliateLink.astro';
import AdSense from '../components/AdSense.astro';
import Calculator from '../components/Calculator.astro';
import { Calculator as CalcIcon, TrendingUp, PiggyBank, Shield, BookOpen } from '@lucide/astro';

const title = 'Compound Interest Calculator — Free Investment & Savings Growth Tool';
const description = 'Calculate compound interest for free. Plan investments, savings, retirement, and CDs with charts, yearly breakdowns, and copyable results.';
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT;

const features = [
  {
    icon: CalcIcon,
    title: 'Easy Calculations',
    description: 'Enter principal, monthly contributions, rate, and years to see your future balance instantly.',
  },
  {
    icon: TrendingUp,
    title: 'Visual Growth Charts',
    description: 'See your balance grow year by year with a clear inline SVG bar chart.',
  },
  {
    icon: PiggyBank,
    title: 'Multiple Scenarios',
    description: 'Plan investments, savings, retirement, and CDs all in one place.',
  },
  {
    icon: Shield,
    title: 'Privacy Friendly',
    description: 'Calculations run in your browser. No account or personal data required.',
  },
];

const guides = [
  {
    title: 'What Is Compound Interest?',
    href: '/blog/what-is-compound-interest/',
  },
  {
    title: 'Compound Interest vs. Simple Interest',
    href: '/blog/compound-interest-vs-simple-interest/',
  },
  {
    title: 'How to Start Investing',
    href: '/blog/how-to-start-investing/',
  },
  {
    title: 'Best Compound Interest Accounts',
    href: '/blog/best-compound-interest-accounts/',
  },
  {
    title: 'The Rule of 72',
    href: '/blog/rule-of-72/',
  },
];

const faq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is compound interest?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Compound interest is the interest earned on both your original money and the interest that has already been added to your account. Over time, this creates exponential growth.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I use the compound interest calculator?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Enter your initial investment, monthly contribution, expected annual return, investment length, and compounding frequency. The calculator shows your total balance, contributions, interest earned, and a year-by-year breakdown.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the best compounding frequency?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'More frequent compounding generally yields slightly higher returns, but the difference between monthly and daily compounding is usually small. The annual return and time invested matter far more.',
      },
    },
  ],
};

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Compound Interest Calculator',
    url: Astro.site?.toString() ?? 'https://compoundgrowcalculator.com',
    description,
  },
  faq,
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Compound Interest Calculator',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Any',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    description,
    url: `${Astro.site?.toString().replace(/\/$/, '') ?? 'https://compoundgrowcalculator.com'}/tools/compound-interest-calculator/`,
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section
    class="relative py-16 sm:py-24 text-white"
    style="background-image: url('/hero-bg.svg'); background-size: cover; background-position: center;"
  >
    <div class="absolute inset-0 bg-emerald-950/40"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight drop-shadow-lg">
        Free Compound Interest Calculator
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-emerald-50 max-w-2xl mx-auto drop-shadow-md">
        Plan your investments, savings, retirement, and CDs. See how compound interest grows your money with charts and year-by-year breakdowns.
      </p>
    </div>
  </section>

  <section class="pb-12 sm:pb-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      {adsenseClient && <AdSense client={adsenseClient} slot="1234567891" format="horizontal" className="mb-8" />}

      <Calculator />

      {adsenseClient && <AdSense client={adsenseClient} slot="1234567892" format="rectangle" className="mt-8" />}
    </div>
  </section>

  <section class="py-16 sm:py-20 border-t border-slate-200 dark:border-slate-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          features.map((feature) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow dark:border-slate-800 dark:bg-slate-900">
              <div class="mb-4 inline-flex items-center justify-center rounded-lg bg-primary-100 p-3 text-primary-700 dark:bg-primary-900/40 dark:text-primary-400">
                <feature.icon size={24} />
              </div>
              <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">{feature.title}</h3>
              <p class="mt-2 text-slate-600 dark:text-slate-400">{feature.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-slate-200 bg-slate-50 py-16 dark:border-slate-800 dark:bg-slate-900">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-slate-100">Explore Our Tools</h2>
        <p class="mt-4 text-slate-600 dark:text-slate-400">Choose the calculator that fits your financial goal.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <a href="/tools/compound-interest-calculator/" class="block rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-primary-300 transition-all dark:border-slate-800 dark:bg-slate-950 dark:hover:border-primary-700">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Compound Interest</h3>
          <p class="mt-2 text-slate-600 dark:text-slate-400">The main calculator for any compounding scenario.</p>
        </a>
        <a href="/tools/investment-growth-calculator/" class="block rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-primary-300 transition-all dark:border-slate-800 dark:bg-slate-950 dark:hover:border-primary-700">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Investment Growth</h3>
          <p class="mt-2 text-slate-600 dark:text-slate-400">Project stock and portfolio growth over time.</p>
        </a>
        <a href="/tools/savings-growth-calculator/" class="block rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-primary-300 transition-all dark:border-slate-800 dark:bg-slate-950 dark:hover:border-primary-700">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Savings Growth</h3>
          <p class="mt-2 text-slate-600 dark:text-slate-400">Estimate high-yield savings account balances.</p>
        </a>
        <a href="/tools/retirement-savings-calculator/" class="block rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-primary-300 transition-all dark:border-slate-800 dark:bg-slate-950 dark:hover:border-primary-700">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Retirement Savings</h3>
          <p class="mt-2 text-slate-600 dark:text-slate-400">Plan your nest egg and retirement timeline.</p>
        </a>
      </div>
      <div class="mt-6 text-center">
        <a href="/tools/" class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-primary-700 transition-colors">
          View All Tools
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20 border-t border-slate-200 dark:border-slate-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-slate-100">Financial Guides</h2>
        <p class="mt-4 text-slate-600 dark:text-slate-400">Learn the fundamentals of compound interest and smart investing.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          guides.map((guide) => (
            <a href={guide.href} class="flex items-center gap-3 rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:shadow-md hover:border-primary-300 transition-all dark:border-slate-800 dark:bg-slate-900 dark:hover:border-primary-700">
              <BookOpen size={20} class="text-primary-600 dark:text-primary-400" />
              <span class="font-medium text-slate-900 dark:text-slate-100">{guide.title}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-slate-200 bg-slate-50 py-16 dark:border-slate-800 dark:bg-slate-900">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-slate-100">Ready to grow your money?</h2>
      <p class="mt-4 text-slate-600 dark:text-slate-400">
        Try the free calculator or explore our recommended financial partners.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-6">
        <AffiliateLink href="https://investor.vanguard.com/" label="Open an account at Vanguard" />
        <AffiliateLink href="https://www.fidelity.com/" label="Fidelity" />
        <AffiliateLink href="https://www.betterment.com/" label="Betterment" />
      </div>
    </div>
  </section>
</Layout>
