---
import ToolLayout from '../../components/ToolLayout.astro';
import Calculator from '../../components/Calculator.astro';
import AffiliateLink from '../../components/AffiliateLink.astro';

const title = 'CD Interest Calculator — Certificate of Deposit Returns';
const description = 'Calculate how much interest you can earn with a certificate of deposit. Enter your deposit, APY, term length, and compounding frequency to see your maturity balance.';

const faq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is a certificate of deposit?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A certificate of deposit, or CD, is a savings product that pays a fixed interest rate for a fixed term. You agree to leave your money in the account until the CD matures.',
      },
    },
    {
      '@type': 'Question',
      name: 'How is CD interest calculated?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'CD interest is calculated using your deposit amount, annual percentage yield, compounding frequency, and term length. Most CDs compound daily or monthly.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are CDs a good investment?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'CDs are a safe option for money you cannot afford to lose and do not need immediate access to. They typically offer higher rates than regular savings accounts but lower long-term returns than stocks.',
      },
    },
  ],
};

const jsonLd = [faq];
---

<ToolLayout title={title} description={description} jsonLd={jsonLd}>
  <p class="text-slate-600 dark:text-slate-400 mb-6">
    A certificate of deposit, or CD, is one of the safest places to park your cash. When you open a CD, you agree to leave your money with the bank for a set period, known as the term. In exchange, the bank pays you a fixed interest rate that is usually higher than what you would earn in a regular savings account. CDs are insured by the FDIC up to applicable limits, making them a low-risk option for conservative savers.
  </p>
  <p class="text-slate-600 dark:text-slate-400 mb-6">
    Our CD interest calculator helps you estimate how much your certificate of deposit will be worth at maturity. Enter your initial deposit, the annual percentage yield offered by the bank, the length of the CD term in years, and how often interest compounds. The calculator will show your total balance at maturity, how much interest you earned, and a year-by-year breakdown of your CD growth.
  </p>
  <p class="text-slate-600 dark:text-slate-400 mb-6">
    Keep in mind that CDs usually penalize you for withdrawing money before the term ends. Because of this, they work best for money you will not need during the CD term. Many people use CDs for goals that are one to five years away, such as a future home purchase, a wedding, or a planned vacation. Laddering CDs, or opening several CDs with staggered maturity dates, is a popular strategy to maintain some flexibility while locking in higher rates.
  </p>

  <Calculator />

  <section class="mt-12 prose prose-slate max-w-none">
    <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100">CD Investing Tips</h2>
    <ul>
      <li><strong>Compare APYs:</strong> Rates vary widely between banks, especially online banks.</li>
      <li><strong>Check penalties:</strong> Understand early withdrawal penalties before committing.</li>
      <li><strong>Consider CD laddering:</strong> Stagger maturity dates to balance rates and liquidity.</li>
      <li><strong>Keep emergency funds elsewhere:</strong> CDs are not ideal for money you might need quickly.</li>
      <li><strong>Reinvest at maturity:</strong> Decide in advance whether to renew or move the funds.</li>
    </ul>

    <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mt-8">Compare CD Options</h2>
    <p>
      Shop for competitive CD rates at
      <AffiliateLink href="https://www.marcus.com/us/en/savings/certificates-of-deposit" label="Marcus by Goldman Sachs" />,
      <AffiliateLink href="https://www.ally.com/bank/cd/" label="Ally Bank" />,
      <AffiliateLink href="https://www.fidelity.com/" label="Fidelity" />, and
      <AffiliateLink href="https://www.schwab.com/" label="Charles Schwab" />.
    </p>

    <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mt-8">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {faq.mainEntity.map((item) => (
        <details class="rounded-xl border border-slate-200 bg-white p-4 dark:border-slate-800 dark:bg-slate-900">
          <summary class="font-semibold text-slate-900 dark:text-slate-100 cursor-pointer">{item.name}</summary>
          <p class="mt-2 text-slate-600 dark:text-slate-400">{item.acceptedAnswer.text}</p>
        </details>
      ))}
    </div>
  </section>
</ToolLayout>
