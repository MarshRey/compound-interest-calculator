---
import Layout from './Layout.astro';
import AdSense from './AdSense.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, canonical, image, jsonLd } = Astro.props;
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT;
---

<Layout title={title} description={description} canonical={canonical} image={image} jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100">{title}</h1>
      <p class="mt-3 text-lg text-slate-600 dark:text-slate-400">{description}</p>
    </header>
    <slot />
    {adsenseClient && <AdSense client={adsenseClient} slot="1234567893" format="auto" className="mt-12" />}
  </article>
</Layout>
